@page "/myaccount"
@inherits BasePage
@inject IMapper mapper;
@inject IAccountService AccountService
@inject IAlertService AlertService
@inject UserStateService UserStateService
@inject NavigationManager NavigationManager
@inject UtilsService UtilsService
@inject HttpClient Http
@using System.Text.Json
@using System.Globalization

<PageTitle>@loc["Account_My_Account"] | @Globals.AppName</PageTitle>

@if (isLoading)
{
    <MudProgressCircular Class="m-4" Color="Color.Primary" />
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <MudAlert Severity="Severity.Error">@errorMessage</MudAlert>
}
else
{
    <AuthorizeView>
        <MudPaper Class="mudPaperTop">
            <div class="mud-table-toolbar titlePage">
                <MudText Class="d-flex justify-center" Typo="Typo.h6">@loc["Account_My_Account"]</MudText>
            </div>
        </MudPaper>
        <EditForm Model="userDto" OnValidSubmit="OnValidSubmit" Context="editForm">
            <DataAnnotationsValidator />
            <MudGrid>
                <MudItem xs="12">
                    <MudPaper Class="mudPaperBottom pa-4">
                        <MudTextField T="string" Label="@loc["Account_Full_Name"]" @bind-Value="userDto.FullName" Required RequiredError="@loc["Validation_Required"]" />
                    </MudPaper>
                    <MudPaper Class="pa-4 mt-4">
                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">@loc["X_Save"]</MudButton>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </EditForm>

        <div class="mt-8">
            <div class="d-flex justify-content-center">
                <MudText Typo="Typo.h6">Premium status: </MudText>
                @if (UserStateService.CurrentUser.IsPremium)
                {
                    <MudText Typo="Typo.h6">ACTIVE</MudText>
                    <MudText Typo="Typo.h6">XXXX: @UserStateService.CurrentUser.DatePremium</MudText>
                }
                else
                {
                    <MudText Typo="Typo.h6">NO ACTIVE</MudText>
                }
            </div>

            <div class="d-flex justify-content-center mt-2">
                <MudButton ButtonType="ButtonType.Button" Variant="Variant.Filled" Color="Color.Primary" OnClick='() => PremiumNotePopup()'>Premium</MudButton>
            </div>
        </div>
    </AuthorizeView>
}

@code {
    [Parameter]
    public UserDto userDto { get; set; }
    public DialogData dialogData = new DialogData();
    private List<PremiumItem> PremiumItems = new List<PremiumItem>();
    private string CurrentLang => CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;

    protected override async Task LoadDataAsync()
    {
        if (!await EnsureLoggedInAsync())
        {
            return;
        }

        userDto = UserStateService.CurrentUser;

        var json = await Http.GetStringAsync("premium.json");
        var options = new JsonSerializerOptions
        {
            PropertyNameCaseInsensitive = true
        };

        PremiumItems = JsonSerializer.Deserialize<List<PremiumItem>>(json, options);

        var protifts = PremiumItems.Select(x => x.Profit[CurrentLang]);
        var protifts2 = string.Join("\n", protifts);

        dialogData = new DialogData()
        {
            Title = $"{loc["Premium_TopSection"]}",
            ButtonName = $"{loc["X_Save"]}",
            Content = $"{loc["Premium_MainSection"]}\n\n" + protifts2 + $"\n\n{loc["Premium_FooterSection"]}",
        };
    }

    private async Task OnValidSubmit(EditContext context)
    {
        var editDto = mapper.Map<EditUserDto>(userDto);
        await AccountService.EditUser(editDto);
        UserStateService.CurrentUser.FullName = editDto.FullName;
        AlertService.SetSuccessAlert($"You new Fullname is: {editDto.FullName}");
        NavigationManager.NavigateTo("/");
        _ = AlertService.ClearAlertAfterDelay();
    }

    private void PremiumNotePopup()
    {
        var dialogPremium = new DialogData()
        {
            Title = dialogData.Title,
            ButtonName = dialogData.ButtonName,
            Content = dialogData.Content,
        };
        UtilsService.OpenDialog(dialogPremium, () => _ = SetPremium(), Color.Primary);
    }

    private async Task SetPremium()
    {
        Console.WriteLine("Get premium");
        await AccountService.SetPremium(true);
    }
}
